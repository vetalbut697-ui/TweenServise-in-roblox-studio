local TweenService = game:GetService("TweenService")-- Підключення сервісу
local part = script.Parent -- Змінна в якій лежить той об'єкт до якого буде примінено сервіс

-- Налаштування процесу анімації
local info = TweenInfo.new(
	10, -- Час у секундах, склільки часу займе анімація об'єкту
	Enum.EasingStyle.Sine, -- Стиль (плавно(Sine), різко(Linear, для чіткого руху Quad або Cubic), з відскоком(Bounce — об'єкт поводиться як м'ячик, Elastic — ефект гумки або пружини) для останнього також важливовраховувати напрямок 
	--Out (найпопулярніший) — відскок буде в кінці руху.
	--In — відскок (або розгін) буде на початку.
	--InOut — ефект буде і на початку, і в кінці.)
	Enum.EasingDirection.Out, -- Напрямок стилю
	3, -- Скільки разів повторити (-1 для нескінченності)
	true, -- Чи повертатися назад (Reverses)
	0 -- Затримка перед початком
)

-- Що саме міняється під час анімації (пишемо в таблиці)
local goals = {
	Position = part.Position + Vector3.new(0, 10, 0), -- Злетіти вгору
	Color = Color3.fromRGB(255, 0, 0), -- Стати червоним
	Transparency = 0.5 -- Стати напівпрозорим
}

task.wait(3)
-- Створення та запуск анімації
local tween = TweenService:Create(part, info, goals)-- в дужках назва об'єкту та назви таблиць створених вище
tween:Play()
